<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  AguaYLuz weekly refresh (USGS site network + levels + EPA SDWIS + export).
  Edit the __ABSOLUTE_PATH__ placeholders and the EPA key, then:
    cp scripts/deploy/com.aguayluz.refresh-weekly.plist ~/Library/LaunchAgents/
    launchctl load ~/Library/LaunchAgents/com.aguayluz.refresh-weekly.plist
  Runs Mondays at 06:30 local. Logs to logs/refresh-weekly.{out,err}.
-->
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.aguayluz.refresh-weekly</string>
  <key>ProgramArguments</key>
  <array>
    <string>__ABSOLUTE_PATH_TO_REPO__/.venv/bin/python</string>
    <string>__ABSOLUTE_PATH_TO_REPO__/scripts/refresh.py</string>
    <string>--weekly</string>
  </array>
  <key>WorkingDirectory</key>
  <string>__ABSOLUTE_PATH_TO_REPO__</string>
  <key>EnvironmentVariables</key>
  <dict>
    <key>EPA_WATERS_API_KEY</key>
    <string></string>
  </dict>
  <key>StartCalendarInterval</key>
  <dict>
    <key>Weekday</key><integer>1</integer>
    <key>Hour</key><integer>6</integer>
    <key>Minute</key><integer>30</integer>
  </dict>
  <key>StandardOutPath</key>
  <string>__ABSOLUTE_PATH_TO_REPO__/logs/refresh-weekly.out</string>
  <key>StandardErrorPath</key>
  <string>__ABSOLUTE_PATH_TO_REPO__/logs/refresh-weekly.err</string>
  <key>RunAtLoad</key>
  <false/>
</dict>
</plist>
