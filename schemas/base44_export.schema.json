{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jotaele44/aguayluz-pr/schemas/base44_export.schema.json",
  "title": "Base44ExportEnvelope",
  "description": "Sanitized export envelope sent to the Base44 / thehub-pr control plane. Mirrors the skill-spec Base44 Export Envelope.",
  "type": "object",
  "required": [
    "module_id",
    "run_id",
    "vector",
    "status",
    "coverage_pct",
    "records_total",
    "records_review",
    "records_blocked",
    "confidence_avg",
    "source_manifest_path",
    "integration_report_path",
    "sanitized_summary",
    "top_findings",
    "contradictions",
    "gaps",
    "next_actions"
  ],
  "additionalProperties": false,
  "properties": {
    "module_id": { "const": "aguayluz-pr" },
    "run_id":    { "type": "string", "pattern": "^[0-9]{8}T[0-9]{6}Z_[A-Za-z0-9_-]+$" },
    "vector":    { "type": "string", "minLength": 1 },
    "status":    { "enum": ["PASS", "WARN", "FAIL", "BLOCKED"] },
    "coverage_pct":    { "type": "number", "minimum": 0, "maximum": 100 },
    "records_total":   { "type": "integer", "minimum": 0 },
    "records_review":  { "type": "integer", "minimum": 0 },
    "records_blocked": { "type": "integer", "minimum": 0 },
    "confidence_avg":  { "type": "number", "minimum": 0, "maximum": 100 },
    "source_manifest_path": { "type": "string", "minLength": 1 },
    "integration_report_path": { "type": "string", "minLength": 1 },
    "sanitized_summary": { "type": "string", "description": "No raw evidence, no API keys, no precise private-address targeting." },
    "top_findings":    { "type": "array", "items": { "type": "object" } },
    "contradictions":  { "type": "array", "items": { "type": "object" } },
    "gaps":            { "type": "array", "items": { "type": "string" } },
    "next_actions":    { "type": "array", "items": { "type": "string" } }
  }
}
