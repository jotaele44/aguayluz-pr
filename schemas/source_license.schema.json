{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "source_license.schema.json",
  "title": "SourceLicense",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "license_id",
    "license_name",
    "reuse_allowed",
    "derivatives_allowed",
    "attribution_required",
    "location_precision_allowed",
    "redistribution_allowed",
    "required_citation"
  ],
  "properties": {
    "license_id": {"type": "string", "pattern": "^license_[A-Fa-f0-9]{12,64}$"},
    "license_name": {"type": "string", "minLength": 1},
    "license_url": {"type": ["string", "null"]},
    "reuse_allowed": {"type": "boolean"},
    "commercial_use_allowed": {"type": ["boolean", "null"]},
    "derivatives_allowed": {"type": "boolean"},
    "attribution_required": {"type": "boolean"},
    "attribution_text": {"type": ["string", "null"]},
    "location_precision_allowed": {
      "type": "string",
      "enum": ["precise", "generalized", "prohibited"]
    },
    "redistribution_allowed": {
      "type": "string",
      "enum": ["full", "derived_only", "none"]
    },
    "required_citation": {"type": "string", "minLength": 1},
    "notes": {"type": ["string", "null"]}
  }
}
