{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "grid_cell_aggregation.schema.json",
  "title": "GridCellAggregation",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "grid_id",
    "grid_scheme",
    "grid_resolution",
    "centroid_lat",
    "centroid_lon",
    "municipalities",
    "observation_count",
    "verified_count",
    "taxa_count",
    "mean_confidence",
    "source_count",
    "attribution_refs",
    "precision_mode",
    "review_status"
  ],
  "properties": {
    "grid_id": {"type": "string", "pattern": "^myc_grid_[A-Fa-f0-9]{12,64}$"},
    "grid_scheme": {"type": "string", "enum": ["degree_bin", "h3", "geohash", "custom_pr_grid"]},
    "grid_resolution": {"type": "string", "minLength": 1},
    "geometry": {"type": ["object", "null"]},
    "centroid_lat": {"type": "number", "minimum": 17.5, "maximum": 18.7},
    "centroid_lon": {"type": "number", "minimum": -67.4, "maximum": -65.0},
    "municipalities": {"type": "array", "items": {"type": "string"}},
    "observation_count": {"type": "integer", "minimum": 0},
    "verified_count": {"type": "integer", "minimum": 0},
    "taxa_count": {"type": "integer", "minimum": 0},
    "dominant_habitat_context": {"type": ["string", "null"]},
    "dominant_substrate": {"type": ["string", "null"]},
    "first_observed_at": {"type": ["string", "null"], "format": "date-time"},
    "last_observed_at": {"type": ["string", "null"], "format": "date-time"},
    "mean_confidence": {"type": "number", "minimum": 0, "maximum": 100},
    "source_count": {"type": "integer", "minimum": 0},
    "attribution_refs": {"type": "array", "items": {"type": "string", "pattern": "^obs_src_[A-Fa-f0-9]{12,64}$"}},
    "precision_mode": {"type": "string", "enum": ["precise_research", "aggregate_public"]},
    "review_status": {"type": "string", "enum": ["accepted", "needs_review", "blocked"]}
  }
}
