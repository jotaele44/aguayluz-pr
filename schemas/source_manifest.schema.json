{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jotaele44/aguayluz-pr/schemas/source_manifest.schema.json",
  "title": "SourceManifest",
  "description": "Per-output source manifest. Every produced record traces back here.",
  "type": "object",
  "required": ["module_id", "generated_at", "entries"],
  "additionalProperties": false,
  "properties": {
    "module_id": { "const": "aguayluz-pr" },
    "generated_at": { "type": "string", "format": "date-time" },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["source_ref", "tier", "access_date"],
        "additionalProperties": false,
        "properties": {
          "source_ref":  { "type": "string", "minLength": 1 },
          "source_hash": { "type": ["string", "null"], "description": "sha256 hex digest or null when not applicable." },
          "tier":        { "enum": ["T1", "T2", "T3", "T4"] },
          "access_date": { "type": "string", "format": "date" },
          "citation":    { "type": ["string", "null"] },
          "notes":       { "type": ["string", "null"] }
        }
      }
    }
  }
}
