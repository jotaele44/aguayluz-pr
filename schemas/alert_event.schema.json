{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jotaele44/aguayluz-pr/schemas/alert_event.schema.json",
  "title": "AlertEvent",
  "description": "Operational alert event in the AguaYLuz-PR multi-sector alert system. Tracks an evidence-backed hydro/power/weather/contamination/infrastructure event with module classification, severity, confidence, coordinates, and gap status. Harmonized to repo idioms (confidence 0-100, evidence_tier T1-T4, AYL_ ids) while preserving the workbook's operational fields (severity floor, gap_status, covert structural flags).",
  "type": "object",
  "required": [
    "alert_id",
    "module_id",
    "event_type",
    "status",
    "source_title",
    "source_ref",
    "start_at",
    "asset_name",
    "municipalities",
    "coord_confidence",
    "severity",
    "confidence",
    "gap_status",
    "review_status",
    "evidence_tier"
  ],
  "additionalProperties": false,
  "properties": {
    "alert_id":     { "type": "string", "pattern": "^AYL_ALR_[0-9]{8}_[A-Za-z0-9_-]+$", "description": "Stable unique id, AYL_ALR_<YYYYMMDD>_<slug>." },
    "module_id":    { "enum": ["HYDRO_OPS", "POWER_OPS", "WEATHER_HAZARD", "CONTAMINATION", "TRANSPORT_ACCESS", "TELECOM_SCADA", "DAM_SAFETY", "SEISMIC_GEO", "INDUSTRIAL", "PUBLIC_NOTICE"] },
    "event_type":   { "enum": ["maintenance", "outage", "failure", "quality", "hazard", "inspection", "unknown"] },
    "status":       { "enum": ["draft", "validated", "active", "closed", "rejected"], "description": "Lifecycle state." },
    "source_title": { "type": "string", "minLength": 1, "description": "Title copied/paraphrased from the source." },
    "source_ref":   { "type": "string", "minLength": 1, "description": "Public URL or local archive path of the evidence." },
    "source_hash":  { "type": ["string", "null"], "description": "Evidence integrity hash (sha256 preferred)." },
    "published_at": { "type": ["string", "null"], "format": "date-time" },
    "start_at":     { "type": "string", "format": "date-time", "description": "Operational start time." },
    "end_at":       { "type": ["string", "null"], "format": "date-time" },
    "estimated_duration_hr": { "type": ["number", "null"], "minimum": 0 },
    "asset_name":   { "type": "string", "minLength": 1, "description": "Affected asset." },
    "asset_id":     { "type": ["string", "null"], "description": "Foreign key to a utility_asset master id once matched." },
    "operator":     { "type": ["string", "null"] },
    "municipalities": { "type": "array", "items": { "type": "string", "minLength": 1 }, "minItems": 1 },
    "sectors_impacted": { "type": "array", "items": { "type": "string" }, "default": [] },
    "latitude":     { "type": ["number", "null"], "minimum": 17.7, "maximum": 18.7, "description": "PR mainland + Vieques + Culebra + Mona bounds." },
    "longitude":    { "type": ["number", "null"], "minimum": -67.95, "maximum": -65.2 },
    "coord_confidence": { "enum": ["exact", "approximate", "unknown"] },
    "severity":     { "type": "integer", "minimum": 0, "maximum": 5, "description": "Operational severity (workbook 0-5 scale)." },
    "confidence":   { "type": "integer", "minimum": 0, "maximum": 100, "description": "Analyst/source confidence (repo 0-100 scale)." },
    "ilap_score":   { "type": ["integer", "null"], "minimum": 0, "maximum": 5, "description": "Hydro-ILAP node score if applicable." },
    "covert_flags": { "type": "array", "items": { "type": "string" }, "default": [], "description": "Structural indicators only; no unsupported claims." },
    "gap_status":   { "enum": ["none", "minor", "major", "blocking"], "description": "Data completeness state." },
    "review_status": { "enum": ["accepted", "needs_review", "rejected", "blocked"] },
    "evidence_tier": { "enum": ["T1", "T2", "T3", "T4"] },
    "linked_asset_ids": { "type": "array", "items": { "type": "string" }, "default": [] },
    "validation_notes": { "type": ["string", "null"], "description": "Contradictions, missing fields, verification steps." }
  }
}
